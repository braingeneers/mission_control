# Neuroview is intentionally public and should bypass the shared browser
# authentication flow at the edge.
auth_request off;

# Keep the standard proxy headers for downstream FastAPI.
proxy_set_header X-Real-IP $remote_addr;
proxy_set_header Host $host;
proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

# Debug image metadata saves can include an embedded organoid image payload.
proxy_request_buffering off;
proxy_max_temp_file_size 0;
client_max_body_size 32m;
